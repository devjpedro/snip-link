{
  "name": "@snip-link/api",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun --watch --env-file ../../.env src/http/server.ts",
    "start": "./start.sh",
    "build": "echo '✅ API build complete'",
    "db:generate": "bun --env-file ../../.env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file ../../.env --bun drizzle-kit migrate",
    "db:studio": "bun --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/openapi": "^1.4.6",
    "@node-rs/bcrypt": "^1.10.7",
    "@snip-link/env": "workspace:*",
    "better-auth": "^1.3.13",
    "drizzle-orm": "^0.44.5",
    "elysia": "latest",
    "pg": "^8.16.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.4"
  },
  "exports": {
    "./auth": "./src/http/lib/auth.ts"
  }
}
