# Database
DATABASE_URL="postgresql://docker:docker@localhost:5432/snip-link-db"

# Auth
BETTER_AUTH_SECRET="change-this-to-a-random-secret-key-min-32-chars"
# URL do FRONT. É onde o handler de auth do Next (/api/auth) roda, então é o
# domínio que assina/define o cookie de sessão.
#   dev:  http://localhost:3000
#   prod: https://<seu-app>.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — necessário apenas quando NEXT_PUBLIC_AUTH_MODE=google.
# Crie em https://console.cloud.google.com (OAuth client "Web application").
# Redirect URI autorizado: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Next.js
# Domínio público do FRONT (Vercel em produção).
#   dev:  http://localhost:3000
#   prod: https://<seu-app>.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Domínio da API (Fly.io em produção). O browser nunca chama esta URL
# diretamente: o front faz proxy via /api/proxy (rewrite no next.config) e via
# /api/auth, mantendo o cookie first-party. Usada server-side e no rewrite.
#   dev:  http://localhost:3333
#   prod: https://<sua-api>.fly.dev
NEXT_PUBLIC_API_URL="http://localhost:3333"
# Modo de login: "password" (email/senha + signup, dev) ou "google" (só Google, prod)
NEXT_PUBLIC_AUTH_MODE=password
